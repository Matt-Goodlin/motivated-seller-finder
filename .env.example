# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=msf
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=motivated_seller
DATABASE_URL=postgresql+asyncpg://msf:changeme_strong_password@db:5432/motivated_seller

# ─── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=changeme_generate_a_real_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin bootstrap (created on first run if no users exist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_admin_password

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# In production, set to your actual domain: https://yourdomain.com
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ─── Free Data Sources ────────────────────────────────────────────────────────
# Nominatim (OpenStreetMap geocoding) - no key needed, just your contact email
NOMINATIM_USER_AGENT=motivated-seller-finder/1.0 your@email.com

# US Census API (free, register at https://api.census.gov/data/key_signup.html)
CENSUS_API_KEY=

# Socrata open data (building permits) - optional, increases rate limits
SOCRATA_APP_TOKEN=

# ─── Paid Data Sources (all optional) ────────────────────────────────────────
# ATTOM Data Solutions (https://api.developer.attomdata.com/)
ATTOM_API_KEY=

# BatchData - pre-foreclosure + skip tracing (https://batchdata.com/)
BATCHDATA_API_KEY=

# PropStream (https://propstream.com/)
PROPSTREAM_EMAIL=
PROPSTREAM_PASSWORD=

# RapidAPI key (used for Zillow/Redfin/MLS endpoints)
RAPIDAPI_KEY=

# Google Street View (https://developers.google.com/maps/documentation/streetview)
GOOGLE_STREET_VIEW_API_KEY=

# Mapillary (free open-source street view alternative)
MAPILLARY_CLIENT_TOKEN=
